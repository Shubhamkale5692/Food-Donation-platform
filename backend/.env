# ─────────────────────────────────────────
#  FoodBridge – Local Development .env
#  Copy to .env and fill in real values
# ─────────────────────────────────────────

# --- App ---
PROJECT_NAME=FoodBridge
API_V1_STR=/api/v1

# --- Security (change before going to production!) ---
SECRET_KEY=7f3d2a9c1e8b4f6a0d5c2e7b9f4a1d8c3e6b0f5a2d9c4e7b1f8a3d6c0e5b2f9
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# --- PostgreSQL ---
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456789
POSTGRES_DB=foodbridge

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://redis:6379/0

# --- Email (for certificate delivery) ---
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=5432
MAIL_STARTTLS=true
MAIL_SSL_TLS=false